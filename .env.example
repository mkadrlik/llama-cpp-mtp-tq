# =============================================================================
# llama-cpp-mtp-tq Docker Configuration
# =============================================================================
# ROCm build of AtomicBot-ai/atomic-llama-cpp-turboquant with TurboQuant tbq3
# KV cache compression + NextN MTP speculative decoding for Qwen3.6 MoE models.
# =============================================================================

# ROCm base image
BASE_ROCM_IMAGE=rocm/dev-ubuntu-24.04

# ROCm override gfx version (gfx1100 = RX 7900 series)
HSA_OVERRIDE_GFX_VERSION=11.0.0

# Upstream repo (AtomicBot fork with tbq3 + NextN)
UPSTREAM_REPO=https://github.com/AtomicBot-ai/atomic-llama-cpp-turboquant.git
UPSTREAM_BRANCH=feature/turboquant-kv-cache

# =============================================================================
# Runtime Configuration
# =============================================================================

# Model path on host (mount to /models inside container)
MODEL_PATH=/models/model.gguf

# Server port
SERVER_PORT=8080

# Context length
CTX_SIZE=8192

# GPU devices to expose (0,1,2 for 3x RX 7900 XT)
GPU_DEVICES="0,1,2"

# Tensor split for asymmetric PCIe (GPU0 x16, GPU1/2 x4)
TENSOR_SPLIT=2,1,1

# Main GPU (CPU-attached x16 slot)
MAIN_GPU=0

# =============================================================================
# Inference Flags (Phase 2 — AtomicBot TurboQuant + NextN)
# =============================================================================

# Flash attention
FLASH_ATTN=on

# KV cache quantization (turbo3 = TurboQuant tbq3, ~4.3x compression)
KV_CACHE_TYPE_K=turbo3
KV_CACHE_TYPE_V=turbo3

# NextN MTP speculative decoding (baked into Qwen3.6 MTP models)
SPEC_TYPE=nextn
SPEC_DRAFT_MAX=2
SPEC_DRAFT_MIN=1

# Draft model: reuse loaded target (MTP heads in combined GGUF)
MODEL_DRAFT=SAME_AS_MODEL