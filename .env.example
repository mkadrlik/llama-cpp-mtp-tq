# =============================================================================
# llama-cpp-mtp-tq Docker Configuration
# =============================================================================
#
# Source-Build Image Configuration
# =============================================================================

# ROCm base image
BASE_ROCM_IMAGE=rocm/dev-ubuntu-22.04

# ROCm override gfx version
HSA_OVERRIDE_GFX_VERSION=11.0.0

# Upstream llama.cpp repo (mainline - has MTP)
UPSTREAM_REPO=https://github.com/ggml-org/llama.cpp.git

# AmesianX/TurboQuant repo (tbq3 patches)
AMESIANX_REPO=https://github.com/AmesianX/TurboQuant.git

# =============================================================================
# Runtime Configuration
# =============================================================================

# Model path on host (mount to /models inside container)
MODEL_PATH=/models/model.gguf

# Server port
SERVER_PORT=8080

# Context length
CTX_SIZE=8192

# GPU devices to expose
GPU_DEVICES="0,1,2"

# Tensor split for asymmetric PCIe (GPU0 x16, GPU1/2 x4)
TENSOR_SPLIT=2,1,1

# Main GPU
MAIN_GPU=0

# =============================================================================
# Inference Flags
# =============================================================================

# Flash attention
FLASH_ATTN=on

# KV cache quantization
KV_CACHE_TYPE=tbq3

# MTP speculative decoding
SPEC_TYPE=draft-mtp
SPEC_DRAFT_N_MAX=2