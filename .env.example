# =============================================================================
# llama-cpp-mtp-tq Docker Configuration
# =============================================================================
# Builds mainline ggml-org/llama.cpp with ROCm HIP + MTP speculative decoding.
# No TurboQuant (tbq3) — uses q8_0 KV cache quantization.
# =============================================================================

# ROCm base image
BASE_ROCM_IMAGE=rocm/dev-ubuntu-24.04

# ROCm override gfx version (gfx1100 = RX 7900 series)
HSA_OVERRIDE_GFX_VERSION=11.0.0

# Upstream llama.cpp repo (mainline — has MTP: --spec-type draft-mtp)
UPSTREAM_REPO=https://github.com/ggml-org/llama.cpp.git
UPSTREAM_BRANCH=master

# =============================================================================
# Runtime Configuration
# =============================================================================

# Model path on host (mount to /models inside container)
MODEL_PATH=/models/model.gguf

# Server port
SERVER_PORT=8080

# Context length
CTX_SIZE=8192

# GPU devices to expose (0,1,2 for 3x RX 7900 XT)
GPU_DEVICES="0,1,2"

# Tensor split for asymmetric PCIe (GPU0 x16, GPU1/2 x4)
TENSOR_SPLIT=2,1,1

# Main GPU (CPU-attached x16 slot)
MAIN_GPU=0

# =============================================================================
# Inference Flags
# =============================================================================

# Flash attention
FLASH_ATTN=on

# KV cache quantization (q8_0 is standard; tbq3/turbo not in mainline)
KV_CACHE_TYPE_K=q8_0
KV_CACHE_TYPE_V=q8_0

# MTP speculative decoding (baked into Qwen3.6 MTP models, no draft model needed)
SPEC_TYPE=draft-mtp
SPEC_DRAFT_N_MAX=2
